<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox fx:id="iconBar" maxWidth="180.0"
      prefHeight="190.0" prefWidth="50.0"
      styleClass="icon-bar"
      stylesheets="@../../../stylesheets/iconBar.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.stoynko.hospitaladminhub.core.controllers.IconBarController">

    <!-- MENU ITEMS -->
    <VBox alignment="TOP_CENTER" prefHeight="165.0" prefWidth="108.0" spacing="10">

        <Button fx:id="buttonDashboard" styleClass="icon-bar-button" contentDisplay="GRAPHIC_ONLY"/>

        <Region prefHeight="50"/>

        <Button styleClass="icon-bar-button" userData="ANALYTICS_REFERENCE" contentDisplay="GRAPHIC_ONLY"/>
        <Button styleClass="icon-bar-button" userData="PATIENTS_REFERENCE" contentDisplay="GRAPHIC_ONLY"/>

    </VBox>
</VBox>
